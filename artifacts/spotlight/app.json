{
  "expo": {
    "name": "Spotlight",
    "slug": "spotlight",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "spotlight",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#170A1E"
    },
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Spotlight needs your microphone to record your performances and get AI coaching feedback.",
        "NSCameraUsageDescription": "Spotlight needs your camera to record your performances.",
        "NSUserNotificationUsageDescription": "Spotlight sends daily practice reminders to keep your streak going."
      }
    },
    "android": {
      "permissions": ["RECORD_AUDIO", "POST_NOTIFICATIONS"]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-av",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#E63F6E"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
